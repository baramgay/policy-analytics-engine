# Supabase (미설정 시 자동으로 로컬 데모 모드로 동작)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service-role 키(서버 전용, 비공개). 공유 링크/댓글 API 라우트가 RLS를 우회해 접근할 때만 사용
SUPABASE_SERVICE_ROLE_KEY=

# AI narrator 단일 접점 (Qwen, OpenAI 호환 모드 / 미설정 시 AI 설명 기능만 비활성화, 나머지 분석 기능은 정상 동작)
QWEN_API_KEY=
QWEN_API_HOST=

# 카카오맵 JS SDK (Kakao Developers Console에서 발급, 도메인 등록 필요)
NEXT_PUBLIC_KAKAO_MAP_KEY=
